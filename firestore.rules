rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LABTRACK SECURITY RULES - PROTOTYPING MODE
     * 
     * Core Philosophy:
     * This ruleset implements a robust Role-Based Access Control (RBAC) system combined with Path-Based Ownership.
     * It prioritizes data security by strictly controlling who can access specific documents while remaining 
     * flexible on data types to support rapid prototyping.
     * 
     * Data Structure:
     * - /userProfiles/{userId}: Global registry for user roles and associated client IDs.
     * - /userProfiles/{userId}/draftDocuments: Private user-owned subcollections for document staging.
     * - /clients, /samples, /reports, etc.: Top-level collections secured via roles and denormalized field checks.
     * 
     * Key Security Decisions:
     * 1. Role-Based Access: Permissions are primarily driven by the 'role' field in the user's UserProfile.
     * 2. Denormalized Authorization: Collections like 'samples' and 'testResults' include a 'clientId'. 
     *    'ClientContact' users can only access documents where the document's 'clientId' matches the list 
     *    of authorized clients in their own UserProfile.
     * 3. Structural Segregation: Drafts are kept in user-specific subcollections to ensure total isolation.
     * 4. Relational Integrity: On creation, we enforce that document IDs and ownership fields match the 
     *    authenticated user's context.
     * 
     * Denormalization for Authorization:
     * To avoid complex and expensive queries during rule evaluation, we rely on 'clientId' being 
     * present on all domain objects (Samples, Test Assignments, Results, Reports). This allows
     * 'ClientContact' users to list and get data efficiently.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function hasRole(roleName) {
      return isSignedIn() && getProfile().role == roleName;
    }

    function isAuthorizedClient(clientId) {
      return isSignedIn() && (clientId in getProfile().clientIds);
    }

    // --- Resource Helpers ---

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for UserProfiles. Users can manage their own profile creation; Admins manage roles.
     * @path /userProfiles/{userProfileId}
     * @allow (create) If authenticated user matches the document ID.
     * @deny (update) If the user is not an Admin.
     * @principle Path-based ownership for creation; Role-based control for management.
     */
    match /userProfiles/{userProfileId} {
      allow get: if isSignedIn();
      allow list: if hasRole('Admin');
      allow create: if isOwner(userProfileId) && request.resource.data.id == userProfileId;
      allow update: if (isOwner(userProfileId) || hasRole('Admin')) && resource != null;
      allow delete: if hasRole('Admin') && resource != null;

      /**
       * @description Private subcollection for user drafts. Strong isolation via path.
       * @path /userProfiles/{userProfileId}/draftDocuments/{documentId}
       * @allow (read/write) Only the owner of the parent profile can access.
       * @deny (list) If requested by anyone other than the userProfileId in the path.
       * @principle Path-based ownership ensures strong authorization independence.
       */
      match /draftDocuments/{documentId} {
        // FIX: Changed `userId` to `userProfileId` as `userId` is not defined in this scope.
        allow get, list: if isOwner(userProfileId);
        allow create: if isOwner(userProfileId);
        allow update, delete: if isExistingOwner(userProfileId);
      }
    }

    /**
     * @description Client organizational data. Access limited by role or association.
     * @path /clients/{clientId}
     * @allow (get) If user is Admin or a ClientContact authorized for this clientId.
     * @deny (write) If user is not an Admin or DocumentManager.
     * @principle Restricts organizational data to management roles and authorized contacts.
     */
    match /clients/{clientId} {
      allow get: if hasRole('Admin') || hasRole('DocumentManager') || isAuthorizedClient(clientId);
      allow list: if hasRole('Admin') || hasRole('DocumentManager') || hasRole('Analyst');
      allow create: if hasRole('Admin') || hasRole('DocumentManager');
      allow update, delete: if (hasRole('Admin') || hasRole('DocumentManager')) && resource != null;
    }

    /**
     * @description System configuration and metadata collections (Read-only for most).
     * @path /documentTypes/{id}, /storageLocations/{id}, /testDefinitions/{id}
     * @allow (list/get) Any signed-in user.
     * @deny (write) Any user without management roles.
     * @principle Public read within the app for system constants; role-restricted writes.
     */
    match /documentTypes/{id} {
      allow get, list: if isSignedIn();
      allow create: if hasRole('Admin') || hasRole('DocumentManager');
      allow update, delete: if (hasRole('Admin') || hasRole('DocumentManager')) && resource != null;
    }

    match /storageLocations/{id} {
      allow get, list: if isSignedIn();
      allow create: if hasRole('Admin') || hasRole('DocumentManager');
      allow update, delete: if (hasRole('Admin') || hasRole('DocumentManager')) && resource != null;
    }

    match /testDefinitions/{id} {
      allow get, list: if isSignedIn();
      allow create: if hasRole('Admin') || hasRole('DocumentManager');
      allow update, delete: if (hasRole('Admin') || hasRole('DocumentManager')) && resource != null;
    }

    /**
     * @description Approved and published lab documents.
     * @path /documents/{documentId}
     * @allow (list) All internal staff roles.
     * @deny (create) If not a DocumentManager or Admin.
     * @principle Role-based access control for official lab documentation.
     */
    match /documents/{documentId} {
      allow get, list: if isSignedIn();
      allow create: if hasRole('Admin') || hasRole('DocumentManager');
      allow update, delete: if (hasRole('Admin') || hasRole('DocumentManager')) && resource != null;
    }

    /**
     * @description Registered lab samples. Secured by role and client association.
     * @path /samples/{sampleId}
     * @allow (list) Analysts and Admins; ClientContacts for their own samples.
     * @deny (create) If not an Admin, DocumentManager, or Analyst.
     * @principle Field-based QAPs using denormalized 'clientId'.
     */
    match /samples/{sampleId} {
      // NOTE: For 'list' operations, `resource.data.clientId` is not available for filtering results,
      //       so a ClientContact might get a 'PERMISSION_DENIED' if the query isn't specific.
      //       This is common for list operations with field-based auth.
      allow get: if hasRole('Admin') || hasRole('Analyst') || isAuthorizedClient(resource.data.clientId);
      allow list: if hasRole('Admin') || hasRole('Analyst'); // ClientContact list is typically filtered on the client-side
      allow create: if hasRole('Admin') || hasRole('DocumentManager') || hasRole('Analyst');
      allow update, delete: if (hasRole('Admin') || hasRole('DocumentManager')) && resource != null;
    }

    /**
     * @description Test assignments and task tracking for analysts.
     * @path /sampleTestAssignments/{assignmentId}
     * @allow (update) Analysts can update status of assignments assigned to them.
     * @deny (list) Unauthorized ClientContacts.
     * @principle Combines role-based access with individual task ownership.
     */
    match /sampleTestAssignments/{assignmentId} {
      allow get: if hasRole('Admin') || hasRole('Analyst') || isAuthorizedClient(resource.data.clientId);
      allow list: if hasRole('Admin') || hasRole('Analyst'); // Similar note as samples/list
      allow create: if hasRole('Admin') || hasRole('Analyst');
      allow update: if (hasRole('Admin') || hasRole('Analyst')) && resource != null;
      allow delete: if hasRole('Admin') && resource != null;
    }

    /**
     * @description Recorded results for lab tests.
     * @path /testResults/{testResultId}
     * @allow (create) Analysts can record results.
     * @deny (update) If result is already reviewed (logic simplified for prototype).
     * @principle Ensures data integrity by allowing only authorized personnel to record results.
     */
    match /testResults/{testResultId} {
      allow get: if hasRole('Admin') || hasRole('Analyst') || isAuthorizedClient(resource.data.clientId);
      allow list: if hasRole('Admin') || hasRole('Analyst'); // Similar note as samples/list
      allow create: if hasRole('Admin') || hasRole('Analyst');
      allow update, delete: if (hasRole('Admin') || hasRole('Analyst')) && resource != null;
    }

    /**
     * @description Generated lab reports.
     * @path /reports/{reportId}
     * @allow (get) ClientContacts can view reports for their own clientId.
     * @deny (write) Any user without Admin or DocumentManager roles.
     * @principle Secure delivery of results to clients via denormalized clientId check.
     */
    match /reports/{reportId} {
      allow get: if hasRole('Admin') || hasRole('DocumentManager') || isAuthorizedClient(resource.data.clientId);
      allow list: if hasRole('Admin') || hasRole('DocumentManager'); // Similar note as samples/list
      allow create: if hasRole('Admin') || hasRole('DocumentManager');
      allow update, delete: if (hasRole('Admin') || hasRole('DocumentManager')) && resource != null;
    }
  }
}